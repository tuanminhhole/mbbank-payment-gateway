# MBBank Payment Gateway — Environment Variables

# ── MB Bank Credentials ──
MB_USERNAME=your_mb_username
MB_PASSWORD=your_mb_password
MB_ACCOUNT_NUMBER=your_account_number

# ── Server ──
PORT=3456
ADMIN_SECRET=change_this_to_a_strong_secret

# ── Encryption (32 bytes hex) ──
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Session Keep-Alive ──
# Ping MB Bank every N ms to prevent session timeout (default: 4 min)
KEEP_ALIVE_INTERVAL=240000

# Max ping failures before re-login (default: 3)
MAX_PING_FAILURES=3

# ── Reconciliation ──
# Poll interval when there are pending transactions (default: 30s)
RECON_ACTIVE_INTERVAL=30000

# Poll interval when idle (default: 5 min)
RECON_IDLE_INTERVAL=300000

# ── Transaction ──
# Transaction expiry time (default: 30 min)
TX_EXPIRE_MS=1800000

# ── Logging ──
LOG_LEVEL=info
